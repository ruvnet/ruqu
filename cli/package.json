  "bin": {
    "ruqu": "bin/cli.js"
  },
  "files": [
    "bin/**",
    "src/**",
    "tsconfig.json",
    ".claude/**",
    "CLAUDE.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
