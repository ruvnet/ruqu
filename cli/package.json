    "test": "vitest run",
    "init": "node ./bin/cli.js init",
    "doctor": "node ./bin/cli.js doctor"
  },
  "dependencies": {
    "@metaharness/kernel": "^0.1.0",
    "@metaharness/host-claude-code": "^0.1.0"
  },
